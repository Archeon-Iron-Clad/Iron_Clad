# Copy to .env.local (never commit secrets)

# Convex HTTP URL shown in Convex dashboard (“Deployment URL”).
# IMPORTANT for production (e.g. Vercel): set the SAME variable name (VITE_CONVEX_URL)
# in the host UI and redeploy—the Vite client embeds this at BUILD time only.
#
# Troubleshooting hosted site vs local-only:
# 1. Run `npx convex deploy` so your production Convex deployment includes the latest
#    mutations (e.g. groups.create with `kind`).
# 2. Use production deployment URL from Convex in VITE_CONVEX_URL—not only the dev URL
#    from `npx convex dev` unless you intentionally point production at dev.
#
VITE_CONVEX_URL=
